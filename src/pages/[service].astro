---
import Base from '../layouts/Base.astro';
import ServiceGlyph from '../components/ServiceGlyph.astro';
import { services, brands, company } from '../data/site';

export function getStaticPaths() {
  return services.map((s, i) => ({
    params: { service: s.slug },
    props: { svc: s, prev: services[(i - 1 + services.length) % services.length], next: services[(i + 1) % services.length] }
  }));
}
const { svc, prev, next } = Astro.props;
const svcBrands = brands.filter(b => svc.brands.includes(b.slug));
---
<Base title={`${svc.name} — ${company.name}`} description={svc.hero} accent={svc.accent} accentSoft={svc.accentSoft}>

  <!-- ══════════ HERO ══════════ -->
  <section class="relative pt-32 lg:pt-40 pb-14 overflow-hidden accent-soft-bg">
    <div class="absolute top-10 right-[-4%] w-[44%] max-w-[520px] opacity-90 pointer-events-none hidden md:block" style={`color:${svc.accent}`} aria-hidden="true">
      <ServiceGlyph name={svc.glyph} class="draw w-full h-full" />
    </div>
    <div class="container-x relative">
      <a href="/#services" class="mono-label text-ink-500 hover:text-ink-900 transition inline-flex items-center gap-2">
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        All services
      </a>
      <div class="flex items-center gap-3 mt-8" data-reveal>
        <span class="mono-label accent-text">{svc.num}</span>
        <span class="h-px w-10" style={`background:${svc.accent}`}></span>
        <span class="mono-label text-ink-500">{svc.short}</span>
      </div>
      <h1 class="display d-xl mt-5 max-w-4xl text-balance" data-reveal>{svc.name}</h1>
      <p class="mt-7 text-xl lg:text-2xl text-ink-700 max-w-2xl leading-snug text-pretty" data-reveal>{svc.hero}</p>
      <div class="mt-9 flex flex-wrap gap-3" data-reveal>
        <a href="/#contact" class="btn btn-solid" data-magnetic>Request a quote
          <svg class="arr w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/#contact" class="btn btn-outline">Talk to an engineer</a>
      </div>
    </div>
  </section>

  <!-- ══════════ PHOTO + OVERVIEW ══════════ -->
  <section class="py-16 lg:py-24">
    <div class="container-x grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">
      <div class="lg:col-span-6 framed aspect-[4/3]" data-reveal>
        <img src={svc.images[0]} alt={`${svc.name} — in the field`} class="w-full h-full object-cover" />
      </div>
      <div class="lg:col-span-6" data-reveal>
        <div class="eyebrow mono-label text-ink-500">Overview</div>
        <p class="display d-md mt-6 text-balance leading-[1.1]">{svc.overview}</p>
      </div>
    </div>
  </section>

  <!-- ══════════ SPEC STRIP (optional) ══════════ -->
  {svc.spec && (
    <section class="pb-4">
      <div class="container-x">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-px rounded-3xl overflow-hidden border border-ink-900/10" data-reveal-stagger>
          {svc.spec.map(sp => (
            <div class="bg-white px-6 py-7">
              <div class="display text-3xl accent-text">{sp.value}</div>
              <div class="mono-label text-ink-500 mt-2">{sp.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ══════════ CAPABILITIES ══════════ -->
  <section class="py-16 lg:py-24">
    <div class="container-x">
      <div class="max-w-2xl" data-reveal>
        <div class="eyebrow mono-label text-ink-500">What we deliver</div>
        <h2 class="display d-lg mt-5 text-balance">Built end-to-end. No handoffs.</h2>
      </div>
      <div class="mt-12 grid md:grid-cols-2 gap-x-12 gap-y-10" data-reveal-stagger>
        {svc.capabilities.map((c, i) => (
          <div class="flex gap-5">
            <div class="shrink-0 w-12 h-12 rounded-2xl grid place-items-center" style={`background:${svc.accentSoft};color:${svc.accent}`}>
              <span class="display text-lg">{String(i+1).padStart(2,'0')}</span>
            </div>
            <div>
              <h3 class="display text-2xl">{c.title}</h3>
              <p class="text-ink-600 mt-2 leading-relaxed text-pretty">{c.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════ WIDE IMAGE BAND (2nd image) ══════════ -->
  <section class="pb-16 lg:pb-24">
    <div class="container-x">
      <div class="framed relative aspect-[16/9] md:aspect-[21/9]" data-reveal>
        <img src={svc.images[1]} alt={`${svc.name} — deployment`} class="w-full h-full object-cover" />
        <div class="absolute inset-0" style={`background:linear-gradient(90deg, ${svc.accent}cc 0%, ${svc.accent}40 40%, transparent 70%)`}></div>
        <div class="absolute inset-0 flex items-end p-7 lg:p-12">
          <div class="text-white max-w-md">
            <div class="mono-label opacity-80">In the field</div>
            <p class="display text-2xl lg:text-4xl mt-3 leading-tight text-balance">{svc.short}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════ RELATED BRANDS ══════════ -->
  {svcBrands.length > 0 && (
    <section class="py-12 border-y border-ink-900/10 bg-white">
      <div class="container-x">
        <div class="flex items-center gap-6 flex-wrap" data-reveal>
          <span class="mono-label text-ink-500">Vendors for {svc.name.toLowerCase()}</span>
          <div class="flex items-center gap-8 flex-wrap">
            {svcBrands.map(b => (
              <div class="flex items-center gap-3">
                <img src={b.logo} alt={b.name} class="h-9 max-w-[110px] object-contain" loading="lazy" />
                <span class="text-xs text-ink-400 hidden sm:inline">{b.note}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ══════════ CTA + PREV/NEXT ══════════ -->
  <section class="py-20 lg:py-28">
    <div class="container-x">
      <div class="rounded-3xl p-10 lg:p-16 text-white relative overflow-hidden" style={`background:${svc.accent}`}>
        <div class="absolute -top-24 -right-20 w-80 h-80 rounded-full blur-3xl opacity-40 bg-white pointer-events-none"></div>
        <div class="relative max-w-2xl" data-reveal>
          <h2 class="display d-lg text-balance">Ready to scope your {svc.name.toLowerCase()} project?</h2>
          <p class="mt-4 text-white/80 leading-relaxed">Send a brief — we’ll come back within a business day with a clear plan.</p>
          <a href="/#contact" class="btn mt-7" style="background:#fff;color:#13141d" data-magnetic>Start the conversation
            <svg class="arr w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <!-- prev / next -->
      <div class="grid grid-cols-2 gap-4 mt-6">
        <a href={`/${prev.slug}`} class="group rounded-2xl border border-ink-900/10 p-6 hover:bg-white transition" style={`--accent:${prev.accent}`}>
          <div class="mono-label text-ink-400 flex items-center gap-2"><svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>Previous</div>
          <div class="display text-xl lg:text-2xl mt-2 group-hover:accent-text transition-colors">{prev.name}</div>
        </a>
        <a href={`/${next.slug}`} class="group rounded-2xl border border-ink-900/10 p-6 hover:bg-white transition text-right" style={`--accent:${next.accent}`}>
          <div class="mono-label text-ink-400 flex items-center gap-2 justify-end">Next<svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></div>
          <div class="display text-xl lg:text-2xl mt-2 group-hover:accent-text transition-colors">{next.name}</div>
        </a>
      </div>
    </div>
  </section>
</Base>
