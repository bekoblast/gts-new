---
// Self-drawing line-art glyphs (stroke only, currentColor). Add `draw` class to animate.
interface Props { name: string; class?: string; }
const { name, class: cls = 'w-full h-full' } = Astro.props;
const sw = 2.4;
---
{name === 'network' && (
  <svg class={cls} viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width={sw} stroke-linecap="round" stroke-linejoin="round">
    <line x1="28" y1="32" x2="60" y2="60" /><line x1="92" y1="28" x2="60" y2="60" />
    <line x1="24" y1="84" x2="60" y2="60" /><line x1="96" y1="90" x2="60" y2="60" />
    <line x1="60" y1="60" x2="60" y2="104" />
    <circle cx="60" cy="60" r="9" /><circle cx="28" cy="32" r="6" /><circle cx="92" cy="28" r="6" />
    <circle cx="24" cy="84" r="6" /><circle cx="96" cy="90" r="6" /><circle cx="60" cy="104" r="6" />
  </svg>
)}
{name === 'wireless' && (
  <svg class={cls} viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width={sw} stroke-linecap="round" stroke-linejoin="round">
    <circle cx="60" cy="86" r="6" fill="currentColor" stroke="none" />
    <path d="M40 70a28 28 0 0 1 40 0" /><path d="M30 58a44 44 0 0 1 60 0" /><path d="M20 46a60 60 0 0 1 80 0" />
  </svg>
)}
{name === 'cctv' && (
  <svg class={cls} viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width={sw} stroke-linecap="round" stroke-linejoin="round">
    <rect x="26" y="40" width="52" height="26" rx="5" transform="rotate(-12 52 53)" />
    <path d="M78 46l16-8v30l-16-8" /><circle cx="46" cy="53" r="6" />
    <line x1="40" y1="74" x2="34" y2="98" /><line x1="34" y1="98" x2="54" y2="98" />
  </svg>
)}
{name === 'iot' && (
  <svg class={cls} viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width={sw} stroke-linecap="round" stroke-linejoin="round">
    <rect x="44" y="44" width="32" height="32" rx="7" />
    <line x1="60" y1="20" x2="60" y2="44" /><line x1="60" y1="76" x2="60" y2="100" />
    <line x1="20" y1="60" x2="44" y2="60" /><line x1="76" y1="60" x2="100" y2="60" />
    <circle cx="60" cy="16" r="4" /><circle cx="60" cy="104" r="4" /><circle cx="16" cy="60" r="4" /><circle cx="104" cy="60" r="4" />
    <circle cx="60" cy="60" r="6" />
  </svg>
)}
{name === 'cloud' && (
  <svg class={cls} viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width={sw} stroke-linecap="round" stroke-linejoin="round">
    <path d="M38 78a18 18 0 0 1 2-36 24 24 0 0 1 46 6 16 16 0 0 1-4 30z" />
    <line x1="60" y1="64" x2="60" y2="96" /><path d="M50 74l10-10 10 10" />
  </svg>
)}
{name === 'shield' && (
  <svg class={cls} viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width={sw} stroke-linecap="round" stroke-linejoin="round">
    <path d="M60 18l34 14v22c0 26-18 40-34 48-16-8-34-22-34-48V32z" />
    <path d="M46 60l10 10 20-22" />
  </svg>
)}
{name === 'power' && (
  <svg class={cls} viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width={sw} stroke-linecap="round" stroke-linejoin="round">
    <path d="M64 18L36 64h22l-6 38 32-50H62z" />
  </svg>
)}
