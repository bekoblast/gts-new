---
// Continuous network animation — nodes + edges with data packets flowing forever.
// Represents GTS's persona: "the network behind the business." Native SVG + SMIL (no JS).
---
<div class="hero-network absolute inset-y-0 right-0 w-[62%] pointer-events-none hidden md:block" aria-hidden="true">
  <svg viewBox="0 0 620 600" class="w-full h-full" fill="none" preserveAspectRatio="xMidYMid meet">
    <defs>
      <filter id="pktGlow" x="-60%" y="-60%" width="220%" height="220%">
        <feGaussianBlur stdDeviation="2.4" result="b" />
        <feMerge><feMergeNode in="b" /><feMergeNode in="SourceGraphic" /></feMerge>
      </filter>
    </defs>

    <!-- edges (also serve as motion paths) -->
    <g stroke="rgba(255,255,255,0.16)" stroke-width="1">
      <path id="e1"  d="M340 180 L480 110" />
      <path id="e2"  d="M340 180 L430 330" />
      <path id="e3"  d="M340 180 L250 200" />
      <path id="e4"  d="M340 180 L300 320" />
      <path id="e5"  d="M430 330 L540 280" />
      <path id="e6"  d="M430 330 L470 470" />
      <path id="e7"  d="M430 330 L350 470" />
      <path id="e8"  d="M430 330 L560 400" />
      <path id="e9"  d="M300 320 L350 470" />
      <path id="e10" d="M480 110 L540 280" />
      <path id="e11" d="M250 200 L300 320" />
    </g>

    <!-- pulse rings on the two hub nodes -->
    <circle class="np-ring" cx="340" cy="180" r="9" />
    <circle class="np-ring" cx="430" cy="330" r="9" style="animation-delay:-1.5s" />

    <!-- nodes -->
    <g fill="#fff" class="np-nodes">
      <circle cx="340" cy="180" r="6.5" />
      <circle cx="430" cy="330" r="6.5" />
      <circle cx="480" cy="110" r="4" />
      <circle cx="250" cy="200" r="4" />
      <circle cx="300" cy="320" r="4.5" />
      <circle cx="540" cy="280" r="4" />
      <circle cx="470" cy="470" r="4.5" />
      <circle cx="350" cy="470" r="4.5" />
      <circle cx="560" cy="400" r="3.5" />
    </g>

    <!-- flowing packets -->
    <circle r="3.4" fill="#ffffff" filter="url(#pktGlow)"><animateMotion dur="3.0s" repeatCount="indefinite" rotate="auto"><mpath href="#e1" /></animateMotion></circle>
    <circle r="3.2" fill="#b094ff" filter="url(#pktGlow)"><animateMotion dur="3.6s" begin="0.6s" repeatCount="indefinite"><mpath href="#e2" /></animateMotion></circle>
    <circle r="3.0" fill="#ff8f90" filter="url(#pktGlow)"><animateMotion dur="2.8s" begin="1.1s" repeatCount="indefinite"><mpath href="#e5" /></animateMotion></circle>
    <circle r="3.2" fill="#ffffff" filter="url(#pktGlow)"><animateMotion dur="3.4s" begin="0.3s" repeatCount="indefinite"><mpath href="#e6" /></animateMotion></circle>
    <circle r="3.0" fill="#b094ff" filter="url(#pktGlow)"><animateMotion dur="3.1s" begin="1.7s" repeatCount="indefinite"><mpath href="#e8" /></animateMotion></circle>
    <circle r="3.0" fill="#ffffff" filter="url(#pktGlow)"><animateMotion dur="2.6s" begin="0.9s" repeatCount="indefinite"><mpath href="#e10" /></animateMotion></circle>
    <circle r="3.0" fill="#ff8f90" filter="url(#pktGlow)"><animateMotion dur="3.5s" begin="2.1s" repeatCount="indefinite"><mpath href="#e9" /></animateMotion></circle>
    <circle r="2.8" fill="#b094ff" filter="url(#pktGlow)"><animateMotion dur="3.2s" begin="1.4s" repeatCount="indefinite"><mpath href="#e7" /></animateMotion></circle>
  </svg>
</div>

<style>
  .np-nodes circle { filter: drop-shadow(0 0 4px rgba(255,255,255,0.6)); }
  .np-ring {
    fill: none; stroke: rgba(255,255,255,0.45); stroke-width: 1.2;
    transform-box: fill-box; transform-origin: center;
    animation: npPulse 3.2s ease-out infinite;
  }
  @keyframes npPulse {
    0%   { transform: scale(0.6); opacity: 0.7; }
    100% { transform: scale(3.4); opacity: 0; }
  }
  /* gentle overall drift so the whole graph feels alive */
  .hero-network svg { animation: netDrift 18s ease-in-out infinite alternate; }
  @keyframes netDrift { from { transform: translate(0,0); } to { transform: translate(-10px,8px); } }

  @media (prefers-reduced-motion: reduce) {
    .np-ring, .hero-network svg { animation: none !important; }
  }
</style>
